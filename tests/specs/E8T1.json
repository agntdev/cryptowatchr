              "text": "*Settings*\n\n\u2022 Morning Summary: On at 09:00\n\nMorning summary sends you a daily report of your watched coins at your chosen time.",
              "parse_mode": "Markdown",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Change Summary Time", "callback_data": "settings:summary:time" }],
                  [{ "text": "Turn Off Summary", "callback_data": "settings:summary:disable" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "timezone is persisted across onboarding confirmation",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Timezone set to UTC+3.\n\nYour default settings:\n\u2022 Quiet hours: 22:00\u201307:00 (alerts suppressed while you sleep)\n\u2022 Alert cooldown: 1 hour (no repeat alerts for the same rule)\n\nYou can change these anytime in Settings.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Continue to menu", "callback_data": "onboard:done" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Welcome to CryptoWatchr.\n\nTrack coins, create price alerts, check the latest prices, and tune your quiet hours from the menu below.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Add Coin", "callback_data": "menu:add" },
                    { "text": "My Watchlist", "callback_data": "menu:watchlist" }
                  ],
                  [
                    { "text": "Create Alert", "callback_data": "menu:alerts" },
                    { "text": "My Alerts", "callback_data": "menu:myalerts" }
                  ],
                  [
                    { "text": "Price Check", "callback_data": "menu:price" },
                    { "text": "Settings", "callback_data": "menu:settings" }
                  ],
                  [
                    { "text": "Help", "callback_data": "menu:help" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:back", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "custom quiet hours are persisted during onboarding",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+5", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Timezone set to UTC+5.\n\nYour default settings:\n\u2022 Quiet hours: 22:00\u201307:00 (alerts suppressed while you sleep)\n\u2022 Alert cooldown: 1 hour (no repeat alerts for the same rule)\n\nYou can change these anytime in Settings.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Continue to menu", "callback_data": "onboard:done" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "settings:qhours:change", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "23:00" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What time should your quiet hours end? (HH:MM, 24-hour format)\n\nExample: 07:00",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Keep defaults", "callback_data": "settings:qhours:skip" }],
                  [{ "text": "Back", "callback_data": "settings:back" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "text": "06:00" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Quiet hours set to 23:00\u201306:00."
            }
          },
          { "method": "sendMessage" }
        ]
      }
    ]
  },
