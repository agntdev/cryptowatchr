          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "09:00" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 3 },
        "expect": [
