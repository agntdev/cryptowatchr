[
  {
    "name": "morning summary persists across multiple settings opens",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "settings:summary:enable", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "08:30" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Morning summary is now on at 08:30.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Add Coin", "callback_data": "menu:add" },
                    { "text": "My Watchlist", "callback_data": "menu:watchlist" }
                  ],
                  [
                    { "text": "Create Alert", "callback_data": "menu:alerts" },
                    { "text": "My Alerts", "callback_data": "menu:myalerts" }
                  ],
                  [
                    { "text": "Price Check", "callback_data": "menu:price" },
                    { "text": "Settings", "callback_data": "menu:settings" }
                  ],
                  [
                    { "text": "Help", "callback_data": "menu:help" }
                  ]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 2 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "*Settings*\n\n\u2022 Morning Summary: On at 08:30\n\nMorning summary sends you a daily report of your watched coins at your chosen time.",
              "parse_mode": "Markdown",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Change Summary Time", "callback_data": "settings:summary:time" }],
                  [{ "text": "Turn Off Summary", "callback_data": "settings:summary:disable" }],
                  [{ "text": "Back to menu", "callback_data": "menu:back" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "morning summary persists after /start and re-onboarding",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
