[
  {
    "name": "/price with unknown ticker shows not recognized message (single reply)",
    "steps": [
      {
        "send": { "text": "/price INVALIDCOIN" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "\"INVALIDCOIN\" is not a recognized ticker. Try a known ticker like BTC, ETH, or SOL."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/price without args shows empty watchlist message (single reply)",
    "steps": [
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty.\n\nUse the Add Coin menu or type a ticker to start building your watchlist."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/price BTC returns price or unavailable (single reply)",
    "steps": [
      {
        "send": { "text": "/price BTC" },
        "expect": [
          {
            "method": "sendMessage"
          }
        ]
      }
    ]
  },
  {
    "name": "/price with valid watchlist shows prices without duplicate replies",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price" },
        "expect": [{ "method": "sendMessage" }]
      }
    ]
  }
]