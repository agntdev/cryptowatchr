          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:dir:above", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "not a number" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive number for the price in USD.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Cancel", "callback_data": "alert:cancel" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "text": "0" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive number for the price in USD."
            }
          }
        ]
      },
      {
        "send": { "text": "-5" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Please enter a valid positive number for the price in USD."
            }
          }
        ]
      }
    ]
