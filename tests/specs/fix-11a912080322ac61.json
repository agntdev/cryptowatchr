  {
    "name": "set quiet hours from settings",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "settings:qhours:change", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "23:00" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "What time should your quiet hours end? (HH:MM, 24-hour format)\n\nExample: 07:00",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Keep defaults", "callback_data": "settings:qhours:skip" }],
                  [{ "text": "Back", "callback_data": "settings:back" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "text": "06:00" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Quiet hours set to 23:00\u201306:00." }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "*Settings*\n\n\u2022 Timezone: Not set\n\u2022 Quiet Hours: 23:00\u201306:00\n\u2022 Morning Summary: Off\n\nConfigure your timezone, quiet hours, and morning summary.",
              "parse_mode": "Markdown",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Set Timezone", "callback_data": "settings:tz:change" }
                  ],
                  [
                    { "text": "Change Quiet Hours", "callback_data": "settings:qhours:change" },
                    { "text": "Clear Quiet Hours", "callback_data": "settings:qhours:clear" }
                  ],
                  [
                    { "text": "Turn On Summary", "callback_data": "settings:summary:enable" }
                  ],
                  [
                    { "text": "Back to menu", "callback_data": "menu:back" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "clear quiet hours from settings",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
