[
  {
    "name": "settings menu shows timezone quiet-hours and summary sections",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:settings", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "*Settings*\n\n\u2022 Timezone: Not set\n\u2022 Quiet Hours: Off\n\u2022 Morning Summary: Off\n\nConfigure your timezone, quiet hours, and morning summary.",
              "parse_mode": "Markdown",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "Set Timezone", "callback_data": "settings:tz:change" }
                  ],
                  [
                    { "text": "Set Quiet Hours", "callback_data": "settings:qhours:change" }
                  ],
                  [
                    { "text": "Turn On Summary", "callback_data": "settings:summary:enable" }
                  ],
                  [
                    { "text": "Back to menu", "callback_data": "menu:back" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
