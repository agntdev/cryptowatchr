  {
    "name": "pause alert button suppresses further notifications",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:alerts", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:type:threshold", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:dir:above", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "60000" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "alert:simulate:threshold", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "alert:pause", "messageId": 2 },
        "expect": [
          {
            "method": "answerCallbackQuery",
            "payload": { "text": "Alert paused for 24 hours." }
          },
          {
            "method": "sendMessage",
            "payload": {
              "text": "This alert is paused for 24 hours. You won't receive notifications until the pause expires."
            }
          }
        ]
      }
    ]
  }
