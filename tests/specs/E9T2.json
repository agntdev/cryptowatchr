[
  {
    "name": "/price with a known ticker fetches price",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price BTC" },
        "expect": [{ "method": "sendMessage" }]
      }
    ]
  },
  {
    "name": "/price with no args and coins in watchlist fetches prices",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price" },
        "expect": [{ "method": "sendMessage" }]
      }
    ]
  },
  {
    "name": "Price Check menu button with coins in watchlist fetches prices",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:add", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "watchlist:coin:ETH", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:price", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "/price with no args and empty watchlist shows empty message",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty.\n\nUse the Add Coin menu or type a ticker to start building your watchlist."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Price Check menu button with empty watchlist shows empty message",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:price", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Your watchlist is empty.\n\nUse the Add Coin menu or type a ticker to start building your watchlist."
            }
          }
        ]
      }
    ]
  }
]
