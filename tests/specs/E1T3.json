[
  {
    "name": "customize quiet hours shows start time keyboard",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "onboard:quiet", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Let's set up your quiet hours \u2014 alerts will be suppressed during this window.\n\nWhat time should quiet hours *start*?\nYou can also type a custom time like 23:30.",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "20:00", "callback_data": "quiet:start:20:00" },
                    { "text": "21:00", "callback_data": "quiet:start:21:00" }
                  ],
                  [
                    { "text": "22:00", "callback_data": "quiet:start:22:00" },
                    { "text": "23:00", "callback_data": "quiet:start:23:00" }
                  ],
                  [
                    { "text": "Use default (22:00)", "callback_data": "quiet:start:default" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "selecting quiet start shows quiet end keyboard",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
