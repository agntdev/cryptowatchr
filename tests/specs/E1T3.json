[
  {
    "name": "setting custom quiet hours during onboarding",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "onboard:tz:UTC+3", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Timezone set to UTC+3.\n\nYour default settings:\n\u2022 Quiet hours: 22:00\u201307:00 (alerts suppressed while you sleep)\n\u2022 Alert cooldown: 1 hour (no repeat alerts for the same rule)\n\nYou can change these anytime in Settings.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Continue to menu", "callback_data": "onboard:done" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "keeping default quiet hours by skipping setup",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "onboard:tz:UTC+5", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Timezone set to UTC+5.\n\nYour default settings:\n\u2022 Quiet hours: 22:00\u201307:00 (alerts suppressed while you sleep)\n\u2022 Alert cooldown: 1 hour (no repeat alerts for the same rule)\n\nYou can change these anytime in Settings.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Continue to menu", "callback_data": "onboard:done" }]
                ]
              }
            }
          }
        ]
      },
      {
        "send": { "callback": "onboard:done", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      }
    ]
  },
  {
    "name": "invalid time input shows error during quiet hours setup",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "onboard:tz:UTC-8", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": {
              "text": "Timezone set to UTC-8.\n\nYour default settings:\n\u2022 Quiet hours: 22:00\u201307:00 (alerts suppressed while you sleep)\n\u2022 Alert cooldown: 1 hour (no repeat alerts for the same rule)\n\nYou can change these anytime in Settings.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Continue to menu", "callback_data": "onboard:done" }]
                ]
              }
            }
          }
        ]
      }
    ]
  }
]