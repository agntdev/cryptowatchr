[
  {
    "name": "threshold alert notification includes absolute dollar change",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "onboard:skip", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "menu:alerts", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:type:threshold", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:coin:BTC", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "callback": "alert:dir:above", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "editMessageText" }
        ]
      },
      {
        "send": { "text": "60000" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "alert:simulate:threshold", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "ALERT: BTC moved — old: $59,800.00 → new: $60,500.00 (+$700.00, +1.17%)\nType: Threshold · BTC above $60,000.00",
              "reply_markup": {
                "inline_keyboard": [
                  [
                    { "text": "View Alert" },
                    { "text": "Pause Alert" }
                  ]
                ]
              }
            }
          }
        ]
      }
    ]
  }
]